{
  "id": "autoexceldeploy-service",
  "name": "Auto Excel Deploy",
  "minRoXtraVersion": "8.009.0",
  "actions": [
    {
      "id": "autoexceldeploy",
      "label": "Bericht aus öffentlicher Ansicht erzeugen",
      "configMethod": "autoexceldeployConfig",
      "settings": "main.mjs",
      "serviceFile": "main.mjs",
      "serviceMethod": "autoexceldeploy",
      "fields": [
        {
          "name": "processId",
          "type": "select",
          "onload": "allProcesses"
        },
        {
          "name": "publicViewId",
          "type": "text"
        },
        {
          "name": "reportField",
          "type": "select",
          "onload": "fields ProcessHubFileUpload"
        },
        {
          "name": "fileNameField",
          "type": "select",
          "onload": "fields ProcessHubTextInput"
        }
      ]
    }
  ]
}
